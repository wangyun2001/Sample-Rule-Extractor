{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sample Rule Extractor",
  "version": "0.1.0",
  "identifier": "com.aiprd.ruleextractor",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "样本驱动规则抽取器",
        "label": "main",
        "width": 1360,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
