{
  "name": "sample-driven-rule-extractor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 1420",
    "flow:test": "python scripts/run_flow_test.py",
    "tauri:info": "powershell -ExecutionPolicy Bypass -File scripts/tauri-msvc.ps1 info",
    "tauri:check": "powershell -ExecutionPolicy Bypass -File scripts/tauri-msvc.ps1 check",
    "tauri:dev": "powershell -ExecutionPolicy Bypass -File scripts/tauri-msvc.ps1 dev",
    "tauri:build": "powershell -ExecutionPolicy Bypass -File scripts/tauri-msvc.ps1 build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.9.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.9.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.11",
    "vue-tsc": "^2.2.8"
  }
}
